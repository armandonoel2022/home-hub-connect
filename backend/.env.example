# Copiar como .env y ajustar valores
PORT=3000
JWT_SECRET=cambia_esta_clave_secreta_muy_larga_2024_safeone
JWT_EXPIRES_IN=8h
CORS_ORIGIN=*
# DATA_DIR=C:\intranet-nueva\backend\data  (default: ./data)

# ─── Conexión SOLO LECTURA a gSafeOne (software GENERAL) ───
# Requiere instalar drivers:  npm install mssql msnodesqlv8
# Y el "ODBC Driver 17 for SQL Server" en el servidor Windows.
GENERAL_SQL_AUTH=windows
GENERAL_SQL_HOST=SAFEONE-SERVER\SQL2019
GENERAL_SQL_DB=gSafeOne
GENERAL_SQL_TRUST_CERT=true
GENERAL_SQL_ENCRYPT=false
# Solo si GENERAL_SQL_AUTH=sql:
# GENERAL_SQL_USER=sa
# GENERAL_SQL_PASSWORD=********
# GENERAL_SQL_PORT=1433
