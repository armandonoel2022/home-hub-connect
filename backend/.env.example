# Copiar como .env y ajustar valores
PORT=3000
JWT_SECRET=cambia_esta_clave_secreta_muy_larga_2024_safeone
JWT_EXPIRES_IN=8h
CORS_ORIGIN=*

# ---------------------------------------------------------------------------
# DATA_DIR — Ubicación de los archivos JSON y subidas (uploads).
#
# IMPORTANTE: este directorio DEBE estar FUERA de la carpeta del proyecto
# para que un `git pull` o una re-exportación desde GitHub NO borre los datos.
#
# Default si no se define:
#   - Windows: C:\intranet-data
#   - Otros:   ./data (dentro de backend/, NO recomendado en producción)
#
# Recomendado en el servidor de SafeOne:
DATA_DIR=C:\intranet-data
# ---------------------------------------------------------------------------
